# Pulse-FL Coordinator Server configuration
BETTER_PULSE_HOST=127.0.0.1
BETTER_PULSE_PORT=8000

# Federated Learning Settings
BETTER_PULSE_MIN_CLIENTS_FOR_AGGREGATION=3
BETTER_PULSE_TOTAL_ROUNDS=10

# Database Connection (defaults to sqlite:///storage/better_pulse.db)
# BETTER_PULSE_DATABASE_URL=postgresql://postgres:pulsepass@localhost:5432/better_pulse

# Ollama Settings
BETTER_PULSE_OLLAMA_API_URL=http://localhost:11434
BETTER_PULSE_OLLAMA_MODEL=gemma4:latest

# ECG Signal Model Input Shapes
BETTER_PULSE_ECG_INPUT_CHANNELS=1
BETTER_PULSE_ECG_SEQUENCE_LENGTH=1000
BETTER_PULSE_NUM_CLASSES=2
