# Pulse-FL Coordinator Server configuration
PULSE_FL_HOST=127.0.0.1
PULSE_FL_PORT=8000

# Federated Learning Settings
PULSE_FL_MIN_CLIENTS_FOR_AGGREGATION=3
PULSE_FL_TOTAL_ROUNDS=10

# Database Connection (defaults to sqlite:///storage/pulse_fl.db)
# PULSE_FL_DATABASE_URL=postgresql://postgres:pulsepass@localhost:5432/pulse_fl

# Ollama Settings
PULSE_FL_OLLAMA_API_URL=http://localhost:11434
PULSE_FL_OLLAMA_MODEL=gemma4:latest

# ECG Signal Model Input Shapes
PULSE_FL_ECG_INPUT_CHANNELS=1
PULSE_FL_ECG_SEQUENCE_LENGTH=1000
PULSE_FL_NUM_CLASSES=2
